    "color/lime/500":    { "Value": "#284725" },

    "color/coral/100":   { "Value": "#E2C0C0" },
    "color/coral/200":   { "Value": "#DB9191" },
    "color/coral/300":   { "Value": "#DA5959" },
    "color/coral/400":   { "Value": "#A82A2A" },
    "color/coral/500":   { "Value": "#721616" },

    "color/amber/100":   { "Value": "#EFDCBF" },
    "color/amber/200":   { "Value": "#F1C77C" },
    "color/amber/300":   { "Value": "#E0A734" },
    "color/amber/400":   { "Value": "#B07A26" },
    "color/amber/500":   { "Value": "#79500B" },

    "color/purple/100":  { "Value": "#E7E5F2" },
    "color/purple/200":  { "Value": "#B8B5C6" },
    "color/purple/300":  { "Value": "#89849B" },
    "color/purple/400":  { "Value": "#59546F" },
    "color/purple/500":  { "Value": "#2A2343" },

    "color/static/white":       { "Value": "#FFFFFF" },
    "color/static/black":       { "Value": "#000000" },

    "spacing/0":   { "Value": 0 },
    "spacing/1":   { "Value": 4 },
    "spacing/2":   { "Value": 8 },
    "spacing/3":   { "Value": 12 },
    "spacing/4":   { "Value": 16 },
    "spacing/5":   { "Value": 20 },
    "spacing/6":   { "Value": 24 },
    "spacing/8":   { "Value": 32 },
    "spacing/10":  { "Value": 40 },
    "spacing/12":  { "Value": 48 },
    "spacing/16":  { "Value": 64 },
    "spacing/20":  { "Value": 80 },

    "radius/none": { "Value": 0 },
    "radius/xs":   { "Value": 4 },
