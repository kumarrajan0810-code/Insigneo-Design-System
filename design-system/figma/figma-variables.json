    "color/neutral/600": { "Value": "#52585E" },
    "color/neutral/700": { "Value": "#2C323A" },
    "color/neutral/800": { "Value": "#1C232D" },

    "color/teal/100":    { "Value": "#C1EAE6" },
    "color/teal/200":    { "Value": "#3ECEC6" },
    "color/teal/300":    { "Value": "#31A49E" },
    "color/teal/400":    { "Value": "#27827D" },
    "color/teal/500":    { "Value": "#133E3C" },

    "color/gold/100":    { "Value": "#EFDCBF" },
    "color/gold/200":    { "Value": "#D4B893" },
    "color/gold/300":    { "Value": "#D2AB7A" },
    "color/gold/400":    { "Value": "#AE916A" },
