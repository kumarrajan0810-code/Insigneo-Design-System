    "font-size/5xl":   { "Value": 40 },

    "font-weight/light":     { "Value": 300 },
    "font-weight/regular":   { "Value": 400 },
    "font-weight/medium":    { "Value": 500 },
    "font-weight/semibold":  { "Value": 600 },
    "font-weight/bold":      { "Value": 700 },

    "line-height/tight":    { "Value": 1.2 },
    "line-height/snug":     { "Value": 1.3 },
    "line-height/normal":   { "Value": 1.4 },
    "line-height/relaxed":  { "Value": 1.5 },
    "line-height/loose":    { "Value": 1.6 },

    "border-width/none":    { "Value": 0 },
    "border-width/thin":    { "Value": 1 },
    "border-width/medium":  { "Value": 1.5 },
    "border-width/thick":   { "Value": 2 },

    "icon-size/xs":  { "Value": 16 },
    "icon-size/sm":  { "Value": 20 },
    "icon-size/md":  { "Value": 24 },
    "icon-size/lg":  { "Value": 32 },
    "icon-size/xl":  { "Value": 40 },

    "avatar-size/xs":  { "Value": 24 },
    "avatar-size/sm":  { "Value": 32 },
    "avatar-size/md":  { "Value": 40 },
    "avatar-size/lg":  { "Value": 56 },
    "avatar-size/xl":  { "Value": 72 },

    "touch-target/min":         { "Value": 44 },
    "touch-target/comfortable": { "Value": 48 }
