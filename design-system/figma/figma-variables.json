  "semantic": {
    "$collection": "Semantic",
    "$description": "Usage-based tokens with Light and Dark modes. These alias Primitive values and change per mode.",
    "$modes": ["Light", "Dark"],

    "color/bg/primary":     { "Light": "{primitives.color/static/white}",     "Dark": "{primitives.color/blue/800}" },
    "color/bg/secondary":   { "Light": "{primitives.color/brand/bone-blue}",  "Dark": "{primitives.color/blue/700}" },
    "color/bg/tertiary":    { "Light": "{primitives.color/neutral/50}",       "Dark": "{primitives.color/neutral/800}" },
    "color/bg/inverse":     { "Light": "{primitives.color/brand/navy-blue}",  "Dark": "{primitives.color/brand/bone-blue}" },
    "color/bg/accent":      { "Light": "{primitives.color/blue/50}",          "Dark": "#1A2E3D" },

    "color/surface/default":  { "Light": "{primitives.color/static/white}",     "Dark": "{primitives.color/neutral/800}" },
    "color/surface/raised":   { "Light": "{primitives.color/static/white}",     "Dark": "{primitives.color/neutral/700}" },
    "color/surface/sunken":   { "Light": "{primitives.color/brand/bone-blue}",  "Dark": "{primitives.color/blue/800}" },
    "color/surface/disabled": { "Light": "{primitives.color/neutral/50}",       "Dark": "{primitives.color/neutral/700}" },

    "color/text/primary":    { "Light": "{primitives.color/brand/navy-blue}",   "Dark": "{primitives.color/neutral/50}" },
    "color/text/secondary":  { "Light": "{primitives.color/neutral/600}",       "Dark": "{primitives.color/neutral/300}" },
    "color/text/tertiary":   { "Light": "{primitives.color/neutral/400}",       "Dark": "{primitives.color/neutral/500}" },
    "color/text/inverse":    { "Light": "{primitives.color/static/white}",      "Dark": "{primitives.color/brand/navy-blue}" },
    "color/text/accent":     { "Light": "{primitives.color/brand/insigneo-blue}", "Dark": "{primitives.color/brand/sky-blue}" },
    "color/text/disabled":   { "Light": "{primitives.color/neutral/300}",       "Dark": "{primitives.color/neutral/600}" },
    "color/text/on-accent":  { "Light": "{primitives.color/static/white}",      "Dark": "{primitives.color/blue/800}" },

    "color/icon/primary":    { "Light": "{primitives.color/brand/navy-blue}",   "Dark": "{primitives.color/neutral/100}" },
    "color/icon/secondary":  { "Light": "{primitives.color/neutral/500}",       "Dark": "{primitives.color/neutral/400}" },
    "color/icon/accent":     { "Light": "{primitives.color/brand/insigneo-blue}","Dark": "{primitives.color/brand/sky-blue}" },
    "color/icon/inverse":    { "Light": "{primitives.color/static/white}",      "Dark": "{primitives.color/brand/navy-blue}" },
    "color/icon/disabled":   { "Light": "{primitives.color/neutral/300}",       "Dark": "{primitives.color/neutral/600}" },

    "color/border/default":  { "Light": "{primitives.color/neutral/200}",       "Dark": "{primitives.color/neutral/700}" },
    "color/border/strong":   { "Light": "{primitives.color/neutral/300}",       "Dark": "{primitives.color/neutral/600}" },
    "color/border/subtle":   { "Light": "{primitives.color/neutral/100}",       "Dark": "{primitives.color/neutral/700}" },
    "color/border/accent":   { "Light": "{primitives.color/brand/insigneo-blue}","Dark": "{primitives.color/brand/sky-blue}" },

    "color/interactive/default":  { "Light": "{primitives.color/brand/insigneo-blue}", "Dark": "{primitives.color/brand/sky-blue}" },
    "color/interactive/hover":    { "Light": "{primitives.color/blue/400}",           "Dark": "{primitives.color/blue/200}" },
    "color/interactive/active":   { "Light": "{primitives.color/blue/500}",           "Dark": "{primitives.color/blue/100}" },
    "color/interactive/disabled": { "Light": "{primitives.color/neutral/200}",        "Dark": "{primitives.color/neutral/700}" },

    "color/status/success":       { "Light": "{primitives.color/lime/300}",   "Dark": "{primitives.color/lime/200}" },
    "color/status/success-bg":    { "Light": "{primitives.color/lime/100}",   "Dark": "#1A2D1A" },
    "color/status/success-text":  { "Light": "{primitives.color/lime/500}",   "Dark": "{primitives.color/lime/200}" },
    "color/status/error":         { "Light": "{primitives.color/coral/300}",  "Dark": "{primitives.color/coral/200}" },
    "color/status/error-bg":      { "Light": "{primitives.color/coral/100}",  "Dark": "#2D1A1A" },
    "color/status/error-text":    { "Light": "{primitives.color/coral/500}",  "Dark": "{primitives.color/coral/200}" },
    "color/status/warning":       { "Light": "{primitives.color/amber/300}",  "Dark": "{primitives.color/amber/200}" },
    "color/status/warning-bg":    { "Light": "{primitives.color/amber/100}",  "Dark": "#2D2510" },
    "color/status/warning-text":  { "Light": "{primitives.color/amber/500}",  "Dark": "{primitives.color/amber/200}" },
    "color/status/info":          { "Light": "{primitives.color/brand/insigneo-blue}", "Dark": "{primitives.color/brand/sky-blue}" },
    "color/status/info-bg":       { "Light": "{primitives.color/blue/50}",    "Dark": "#0D1F2D" },
    "color/status/info-text":     { "Light": "{primitives.color/blue/600}",   "Dark": "{primitives.color/blue/200}" },

    "color/chart/1":          { "Light": "{primitives.color/brand/insigneo-blue}", "Dark": "{primitives.color/brand/sky-blue}" },
    "color/chart/2":          { "Light": "{primitives.color/teal/200}",            "Dark": "{primitives.color/teal/200}" },
    "color/chart/3":          { "Light": "{primitives.color/purple/400}",          "Dark": "{primitives.color/purple/200}" },
    "color/chart/4":          { "Light": "{primitives.color/amber/200}",           "Dark": "{primitives.color/amber/200}" },
    "color/chart/5":          { "Light": "{primitives.color/gold/200}",            "Dark": "{primitives.color/gold/200}" },
    "color/chart/6":          { "Light": "{primitives.color/brand/sky-blue}",      "Dark": "{primitives.color/blue/200}" },
    "color/chart/7":          { "Light": "{primitives.color/neutral/500}",         "Dark": "{primitives.color/neutral/300}" },
    "color/chart/positive":   { "Light": "{primitives.color/lime/300}",            "Dark": "{primitives.color/lime/200}" },
    "color/chart/negative":   { "Light": "{primitives.color/coral/300}",           "Dark": "{primitives.color/coral/200}" }
  },

  "components": {
    "$collection": "Components",
    "$description": "Component-level tokens. These alias Semantic values. Single mode — adapts via semantic layer.",
    "$modes": ["Default"],

    "button/primary/bg":          { "Default": "{semantic.color/interactive/default}" },
    "button/primary/text":        { "Default": "{primitives.color/static/white}" },
    "button/primary/radius":      { "Default": "{primitives.radius/md}" },
    "button/primary/padding-x":   { "Default": "{primitives.spacing/6}" },
    "button/primary/padding-y":   { "Default": "{primitives.spacing/3}" },
    "button/primary/min-height":  { "Default": "{primitives.touch-target/min}" },

    "button/secondary/bg":        { "Default": "#00000000" },
    "button/secondary/text":      { "Default": "{semantic.color/interactive/default}" },
    "button/secondary/border":    { "Default": "{semantic.color/interactive/default}" },
    "button/secondary/radius":    { "Default": "{primitives.radius/md}" },
    "button/secondary/padding-x": { "Default": "{primitives.spacing/6}" },
    "button/secondary/padding-y": { "Default": "{primitives.spacing/3}" },
    "button/secondary/min-height":{ "Default": "{primitives.touch-target/min}" },

    "button/ghost/bg":            { "Default": "#00000000" },
    "button/ghost/text":          { "Default": "{semantic.color/text/primary}" },
    "button/ghost/radius":        { "Default": "{primitives.radius/md}" },
    "button/ghost/padding-x":     { "Default": "{primitives.spacing/4}" },
    "button/ghost/padding-y":     { "Default": "{primitives.spacing/2}" },
    "button/ghost/min-height":    { "Default": "{primitives.touch-target/min}" },

    "button/destructive/bg":      { "Default": "{primitives.color/coral/300}" },
    "button/destructive/text":    { "Default": "{primitives.color/static/white}" },
    "button/destructive/radius":  { "Default": "{primitives.radius/md}" },

    "card/bg":                    { "Default": "{semantic.color/surface/default}" },
    "card/border":                { "Default": "{semantic.color/border/subtle}" },
    "card/radius":                { "Default": "{primitives.radius/lg}" },
    "card/padding":               { "Default": "{primitives.spacing/4}" },
    "card/gap":                   { "Default": "{primitives.spacing/3}" },

    "input/bg":                   { "Default": "{semantic.color/surface/sunken}" },
    "input/border":               { "Default": "{semantic.color/border/default}" },
    "input/border-focus":         { "Default": "{semantic.color/border/accent}" },
    "input/border-error":         { "Default": "{semantic.color/status/error}" },
    "input/radius":               { "Default": "{primitives.radius/md}" },
    "input/padding-x":            { "Default": "{primitives.spacing/4}" },
    "input/padding-y":            { "Default": "{primitives.spacing/3}" },
    "input/min-height":           { "Default": "{primitives.touch-target/comfortable}" },
    "input/text":                 { "Default": "{semantic.color/text/primary}" },
    "input/placeholder":          { "Default": "{semantic.color/text/tertiary}" },
    "input/label":                { "Default": "{semantic.color/text/secondary}" },

    "nav-bar/bg":                 { "Default": "{semantic.color/surface/default}" },
    "nav-bar/title":              { "Default": "{semantic.color/text/primary}" },
    "nav-bar/icon":               { "Default": "{semantic.color/icon/primary}" },
    "nav-bar/border":             { "Default": "{semantic.color/border/subtle}" },
    "nav-bar/height":             { "Default": 56 },

    "tab-bar/bg":                 { "Default": "{semantic.color/surface/default}" },
    "tab-bar/border":             { "Default": "{semantic.color/border/subtle}" },
    "tab-bar/icon-active":        { "Default": "{semantic.color/interactive/default}" },
    "tab-bar/icon-inactive":      { "Default": "{semantic.color/icon/secondary}" },
    "tab-bar/label-active":       { "Default": "{semantic.color/interactive/default}" },
    "tab-bar/label-inactive":     { "Default": "{semantic.color/text/tertiary}" },

    "badge/bg":                   { "Default": "{primitives.color/blue/50}" },
    "badge/text":                 { "Default": "{primitives.color/blue/600}" },
    "badge/radius":               { "Default": "{primitives.radius/full}" },
    "badge/padding-x":            { "Default": "{primitives.spacing/3}" },
    "badge/padding-y":            { "Default": "{primitives.spacing/1}" },

    "list-item/bg":               { "Default": "#00000000" },
    "list-item/divider":          { "Default": "{semantic.color/border/subtle}" },
    "list-item/padding-x":        { "Default": "{primitives.spacing/4}" },
    "list-item/padding-y":        { "Default": "{primitives.spacing/3}" },
    "list-item/min-height":       { "Default": "{primitives.touch-target/comfortable}" },

    "bottom-sheet/bg":            { "Default": "{semantic.color/surface/raised}" },
    "bottom-sheet/handle":        { "Default": "{primitives.color/neutral/300}" },
    "bottom-sheet/radius":        { "Default": "{primitives.radius/2xl}" },
    "bottom-sheet/padding":       { "Default": "{primitives.spacing/4}" }
  }
}
