{
  "$description": "Insigneo Design System — Figma Variables Import File. Compatible with Tokens Studio for Figma and the Variables Import plugin. Structured as three collections: Primitives, Semantic (with Light/Dark modes), and Components.",

  "primitives": {
    "$collection": "Primitives",
    "$description": "Raw design values. Do not use directly in designs — use Semantic or Component tokens instead.",
    "$modes": ["Value"],

    "color/brand/navy-blue":       { "Value": "#0D1846" },
    "color/brand/bone-blue":       { "Value": "#E7F1F3" },
    "color/brand/insigneo-blue":   { "Value": "#00B3E6" },
    "color/brand/sky-blue":        { "Value": "#A1E3FB" },

    "color/blue/50":     { "Value": "#E9F4FE" },
    "color/blue/100":    { "Value": "#D2F0FF" },
    "color/blue/200":    { "Value": "#A1E3FB" },
    "color/blue/300":    { "Value": "#00B7EB" },
    "color/blue/400":    { "Value": "#0389C3" },
    "color/blue/500":    { "Value": "#0666A4" },
    "color/blue/600":    { "Value": "#003D66" },
    "color/blue/700":    { "Value": "#0E233F" },
    "color/blue/800":    { "Value": "#021729" },

    "color/neutral/50":  { "Value": "#F6F5F9" },
